# ══════════════════════════════════════════════════════════════
#  AI-Powered SIEM Platform — Environment Configuration
#  Copy this file to backend/.env and fill in your values.
#  ⚠️  NEVER commit backend/.env to Git!
# ══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=siem_db

# ── LLM Provider ─────────────────────────────────────────────
# Options: groq | openai | gemini | none
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_FALLBACK=none

# Groq (free tier available → https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (optional)
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Threat Intelligence ───────────────────────────────────────
# AbuseIPDB (free tier → https://www.abuseipdb.com/register)
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# ── Security ──────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── Log Collection Ports ──────────────────────────────────────
WINLOGBEAT_PORT=5044
SYSLOG_PORT=514

# ── SIEM Thresholds ───────────────────────────────────────────
LOG_RETENTION_DAYS=90
ALERT_THRESHOLD_HIGH=80
ALERT_THRESHOLD_CRITICAL=95
MAX_LOGS_PER_PAGE=100

# ── ML Model Paths ────────────────────────────────────────────
MODEL_PATH=../ml_model/siem_rf_model.pkl
SCALER_PATH=../ml_model/scaler.pkl
ENCODER_PATH=../ml_model/label_encoders.pkl
MITRE_PATH=../ml_model/mitre_mapping.pkl
RETRAIN_INTERVAL_HOURS=24

# ── Notifications (optional) ──────────────────────────────────
# Slack webhook → https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
